{
  "name": "@saas-chassis/sdk",
  "version": "1.0.0",
  "description": "Shared NestJS middleware for SaaS Chassis multi-tenancy, audit, and feature gating",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "extends": "../../tsconfig.base.json",
          "compilerOptions": {
            "outDir": "./dist",
            "declaration": true,
            "declarationMap": true,
            "incremental": false
          }
        }
      }
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.spec.ts",
      "!src/index.ts"
    ]
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "amqp-connection-manager": "^4.0.0",
    "amqplib": "^0.10.0",
    "class-validator": "^0.14.0",
    "ioredis": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typeorm": "^0.3.0",
    "typescript": "^5.3.0"
  }
}
