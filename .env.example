# PostgreSQL
POSTGRES_USER=chassis_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=saas_chassis
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=chassis
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password_here
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Internal service authentication
INTERNAL_SERVICE_TOKEN=your_internal_token_here

# Service ports
IDENTITY_SERVICE_PORT=3001
TENANT_MANAGER_PORT=3002
BILLING_ENGINE_PORT=3003
AUDIT_SERVICE_PORT=3005
LEDGER_SERVICE_PORT=3006
API_GATEWAY_PORT=8080

# Stripe (optional - required for billing)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/billing

# Product routes (optional - set by consuming applications)
# PRODUCT_ROUTES=barimanager=/api/v1/barimanager=http://barimanager:3010
